rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string
    //   - photoURL: string
    //   - plan: string (FREE, PLUS, PRO, ELITE)
    //   - createdAt: timestamp
    //   - theme: string
    //   - mode: string
    //
    // Collection: chats
    // Document ID: {chatId}
    // Fields:
    //   - userId: string (required)
    //   - title: string (required)
    //   - createdAt: timestamp
    //   - updatedAt: timestamp
    //
    // Collection: messages
    // Document ID: {messageId} (under /chats/{chatId}/messages)
    // Fields:
    //   - chatId: string (required)
    //   - role: string (user, assistant)
    //   - content: string (required)
    //   - createdAt: timestamp
    //   - mode: string
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isSystemOwner() {
      return isAuthenticated() && 
             (request.auth.token.email == "officialdevloper19995@gmail.com" || 
              request.auth.token.email == "priyanshukumarrxl948@gmail.com" ||
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'owner');
    }

    function isOwner(userId) {
      return isAuthenticated() && (request.auth.uid == userId || isSystemOwner());
    }

    function isAdmin() {
      return isAuthenticated() && 
             (isSystemOwner() || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin');
    }

    function isNotBanned() {
      return isAuthenticated() && 
             (!exists(/databases/$(database)/documents/users/$(request.auth.uid)) || 
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('status', 'active') == 'active');
    }

    function isRecent(time) {
      return time is timestamp &&
             time > request.time - duration.value(5, 'm') &&
             time < request.time + duration.value(5, 'm');
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidUser(data) {
      let allowedFields = ['uid', 'userId', 'email', 'displayName', 'name', 'username', 'photoURL', 'photo', 'plan', 'createdAt', 'updatedAt', 'theme', 'mode', 'currentModule', 'selectedModel', 'twoFactorEnabled', 'role', 'status', 'credits', 'dailyUsage', 'totalUsage', 'lastReset', 'lastLogin'];
      return hasOnlyAllowedFields(allowedFields) &&
             (isSystemOwner() || isAdmin() || data.get('uid', '') == request.auth.uid || data.get('userId', '') == request.auth.uid) &&
             data.email is string &&
             (!('displayName' in data) || data.displayName is string) &&
             (!('name' in data) || data.name is string) &&
             (!('username' in data) || data.username is string) &&
             (!('photoURL' in data) || data.photoURL is string) &&
             (!('photo' in data) || data.photo is string) &&
             (!('twoFactorEnabled' in data) || data.twoFactorEnabled is bool) &&
             (!('role' in data) || data.role in ['admin', 'user', 'owner']) &&
             (!('status' in data) || data.status in ['active', 'blocked']) &&
             data.plan in ['FREE', 'PLUS', 'PRO', 'ELITE', 'OWNER'] &&
             (!('theme' in data) || data.theme in ['light', 'dark', 'system']) &&
             (!('mode' in data) || data.mode in ['lite', 'smart', 'beast']) &&
             (!('currentModule' in data) || data.currentModule in ['chat', 'code', 'image', 'research']) &&
             (!('selectedModel' in data) || data.selectedModel in ['claude', 'gpt4o', 'deepseek', 'grok', 'llama', 'auto']) &&
             (!('credits' in data) || data.credits is number) &&
             (!('dailyUsage' in data) || data.dailyUsage is number) &&
             (!('totalUsage' in data) || data.totalUsage is number) &&
             (!('lastReset' in data) || data.lastReset is timestamp || data.lastReset == null) &&
             (!('lastLogin' in data) || data.lastLogin is timestamp || data.lastLogin == null) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    function isValidThread(data) {
      let allowedFields = ['userId', 'title', 'isPinned', 'isArchived', 'createdAt', 'updatedAt'];
      return hasOnlyAllowedFields(allowedFields) &&
             data.userId == request.auth.uid &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 100 &&
             (!('isPinned' in data) || data.isPinned is bool) &&
             (!('isArchived' in data) || data.isArchived is bool) &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    function isValidMessage(data) {
      let allowedFields = ['userId', 'threadId', 'sender', 'message', 'timestamp', 'mode', 'modelUsed', 'attachment', 'isStopped'];
      return hasOnlyAllowedFields(allowedFields) &&
             data.userId == request.auth.uid &&
             data.threadId is string &&
             data.sender in ['user', 'ai'] &&
             data.message is string && data.message.size() <= 1000000 &&
             data.timestamp is timestamp &&
             (!('mode' in data) || data.mode in ['lite', 'smart', 'beast']) &&
             (!('modelUsed' in data) || data.modelUsed in ['claude', 'gpt4o', 'deepseek', 'grok', 'llama']) &&
             (!('attachment' in data) || (data.attachment is map && data.attachment.keys().hasAll(['type', 'url', 'name', 'mimeType']))) &&
             (!('isStopped' in data) || data.isStopped is bool);
    }

    function isValidMemory(data) {
      let allowedFields = ['userId', 'content', 'category', 'createdAt'];
      return hasOnlyAllowedFields(allowedFields) &&
             data.userId == request.auth.uid &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 1000 &&
             data.category in ['preference', 'fact', 'instruction'] &&
             data.createdAt is timestamp;
    }

    function isValidSupportTicket(data) {
      let allowedFields = ['userId', 'email', 'subject', 'issueType', 'description', 'status', 'adminReply', 'feedback', 'mediaUrl', 'mediaType', 'createdAt', 'updatedAt'];
      return hasOnlyAllowedFields(allowedFields) &&
             data.userId == request.auth.uid &&
             data.email is string &&
             data.subject is string && data.subject.size() > 0 && data.subject.size() <= 200 &&
             data.issueType in ['Bug', 'Payment', 'Account', 'Other'] &&
             data.description is string && data.description.size() > 0 && data.description.size() <= 5000 &&
             data.status in ['open', 'pending', 'resolved', 'denied'] &&
             (!('adminReply' in data) || data.adminReply is string) &&
             (!('feedback' in data) || (data.feedback is map && data.feedback.keys().hasAll(['rating', 'comment']))) &&
             (!('mediaUrl' in data) || data.mediaUrl is list) &&
             (!('mediaType' in data) || data.mediaType is list) &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    function isValidBroadcast(data) {
      let allowedFields = ['title', 'message', 'type', 'target', 'userIds', 'createdAt', 'expiresAt', 'createdBy'];
      return hasOnlyAllowedFields(allowedFields) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.message is string && data.message.size() > 0 && data.message.size() <= 5000 &&
             data.type in ['info', 'warning', 'update'] &&
             data.target in ['all', 'specific'] &&
             (!('userIds' in data) || data.userIds is list) &&
             data.createdAt is timestamp &&
             (!('expiresAt' in data) || data.expiresAt is timestamp || data.expiresAt == null) &&
             data.createdBy is string;
    }

    function isValidUserBroadcast(data) {
      let allowedFields = ['userId', 'broadcastId', 'read', 'readAt'];
      return hasOnlyAllowedFields(allowedFields) &&
             data.userId == request.auth.uid &&
             data.broadcastId is string &&
             data.read is bool &&
             data.readAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // match /{document=**} {
    //   allow read, write: if isSystemOwner();
    // }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && (request.auth.uid == userId || isAdmin()) && 
                    isValidUser(request.resource.data) &&
                    (isSystemOwner() || isAdmin() || (request.resource.data.get('role', 'user') == 'user' && request.resource.data.plan == 'FREE'));
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin()) && 
                    isValidUser(request.resource.data) &&
                    (isSystemOwner() || isAdmin() || (
                      request.resource.data.get('role', 'user') == resource.data.get('role', 'user') &&
                      // Normal users CANNOT change their plan or role
                      request.resource.data.plan == resource.data.plan &&
                      (request.resource.data.get('credits', 0) == resource.data.get('credits', 0) || request.resource.data.credits is number)
                    ));
      allow delete: if isOwner(userId) || isAdmin();

      match /settings/{configId} {
        allow read, write: if request.auth.uid == userId || isSystemOwner();
      }
    }

    match /threads/{threadId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isNotBanned() && isValidThread(request.resource.data);
      allow update: if isAuthenticated() && isNotBanned() && resource.data.userId == request.auth.uid && 
                    isValidThread(request.resource.data) &&
                    request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /chats/{messageId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isNotBanned() && isValidMessage(request.resource.data);
      allow update: if isAuthenticated() && isNotBanned() && resource.data.userId == request.auth.uid &&
                    isValidMessage(request.resource.data) &&
                    request.resource.data.timestamp == resource.data.timestamp;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /memories/{memoryId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isNotBanned() && isValidMemory(request.resource.data);
      allow update: if isAuthenticated() && isNotBanned() && resource.data.userId == request.auth.uid &&
                    isValidMemory(request.resource.data) &&
                    request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /supportTickets/{ticketId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isNotBanned() && isValidSupportTicket(request.resource.data);
      allow update: if isAuthenticated() && (
                      (resource.data.userId == request.auth.uid && 
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['feedback', 'updatedAt']) &&
                       (!('feedback' in request.resource.data) || (request.resource.data.feedback is map && request.resource.data.feedback.keys().hasAll(['rating', 'comment'])))
                      ) || 
                      isAdmin()
                    );
      allow delete: if isAdmin();
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || (resource.data.userId == 'admin' && isAdmin()));
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Admin Collections
    match /moduleConfigs/{moduleId} {
      allow read: if isAuthenticated();
      allow write: if isSystemOwner();
    }

    match /systemSettings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isSystemOwner();
    }

    match /redeem/{codeId} {
      allow read: if isAuthenticated();
      allow update: if isAuthenticated() && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usedCount']) &&
                    request.resource.data.usedCount == resource.data.usedCount + 1;
      allow write: if isSystemOwner();
    }

    match /userRedeems/{redeemId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isSystemOwner());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSystemOwner();
    }

    match /adminLogs/{logId} {
      allow read, write: if isSystemOwner();
    }

    match /planSettings/{planId} {
      allow read: if true; // Allow public read for plan details
      allow write: if isSystemOwner();
    }

    match /appSettings/{configId} {
      allow read: if true; // Allow even unauthenticated users to see maintenance status
      allow write: if isSystemOwner();
    }

    match /moduleSettings/{settingId} {
      allow read: if true;
      allow write: if isSystemOwner();
    }

    match /broadcasts/{broadcastId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin() && (request.method == 'delete' || isValidBroadcast(request.resource.data));
    }

    match /userBroadcasts/{userBroadcastId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidUserBroadcast(request.resource.data);
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && isValidUserBroadcast(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
